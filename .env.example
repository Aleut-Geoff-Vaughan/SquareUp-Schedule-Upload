# Square Schedule Manager - Environment Configuration
# Copy this file to .env and fill in your values.

# Flask secret key - REQUIRED. The app will refuse to start if this is
# missing or left at the placeholder below. Generate a strong random
# value with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production

# Square environment toggle (sandbox | production), default: sandbox.
# Admins can also flip this at runtime from the dashboard.
SQUARE_ENVIRONMENT=sandbox

# Sandbox credentials (used when SQUARE_ENVIRONMENT=sandbox)
SANDBOX_ACCESS_TOKEN=
SANDBOX_APPLICATION_ID=

# Production credentials (used when SQUARE_ENVIRONMENT=production)
PRODUCTION_ACCESS_TOKEN=
PRODUCTION_APPLICATION_ID=

# Legacy single-token fallback (used if SANDBOX_/PRODUCTION_ vars are unset)
SQUARE_ACCESS_TOKEN=

# Database file path (defaults to schedules.db in the working directory)
DB_PATH=data/schedules.db

# Flask environment (development | production)
FLASK_ENV=development
