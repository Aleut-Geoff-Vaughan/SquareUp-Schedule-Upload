# Square Schedule Manager - Environment Configuration
# Copy this file to .env and fill in your values.

# Flask secret key - generate a strong random value for production
# e.g. python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production

# Square API access token (Production or Sandbox)
# Get from https://developer.squareup.com/apps
SQUARE_ACCESS_TOKEN=

# Database file path (defaults to schedules.db in the working directory)
DB_PATH=data/schedules.db

# Flask environment (development | production)
FLASK_ENV=development
